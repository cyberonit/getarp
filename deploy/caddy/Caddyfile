{
	# Port 80 on the host belongs to the honeypot, so Caddy cannot use the
	# HTTP-01 ACME challenge. Disable redirects; Caddy falls back to TLS-ALPN-01
	# on 443 to issue the getarp.net certificate.
	auto_https disable_redirects
	email admin@getarp.net
}

getarp.net, www.getarp.net {
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Content-Security-Policy "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' wss://getarp.net wss://www.getarp.net"
		-Server
	}

	# WebSocket + REST API -> backend
	@api path /api/*
	reverse_proxy @api api:8000

	# ── Lock down the admin/settings surface (RECOMMENDED) ──
	# Uncomment and set your operator IPs. The public gets the read-only
	# dashboard; settings + admin endpoints become reachable only from here.
	# @admin {
	#   path /api/admin/* /api/auth/*
	#   not remote_ip 203.0.113.10 198.51.100.0/24
	# }
	# respond @admin "forbidden" 403

	# Everything else -> the React dashboard
	reverse_proxy frontend:80
}
