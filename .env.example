# getarp.net — .env reference
# ─────────────────────────────────────────────────────────────────────────
# DO NOT fill this file in and run from it.
# Run  sudo bash deploy/setup.sh  — it prompts for all secrets interactively,
# auto-generates JWT_SECRET + REDIS_PASSWORD, and writes .env with mode 600.
# This file is documentation only.
# ─────────────────────────────────────────────────────────────────────────

DOMAIN=getarp.net
PUBLIC_IFACE=                     # auto-detected by setup.sh from default route
ADMIN_IP=                         # your management IP — Caddy restricts /api/admin to this

# Postgres — set by setup.sh prompt
PG_DB=
PG_USER=
PG_PASSWORD=                      # prompted, never echoed
PG_HOST=postgres
PG_PORT=5432

# Redis
REDIS_PASSWORD=                   # auto-generated (32 random hex chars)
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# API / auth
JWT_SECRET=                       # auto-generated (64 random hex chars)
JWT_EXPIRE_MINUTES=60
ADMIN_USER=                       # prompted
ADMIN_PASSWORD=                   # prompted, never echoed

# Threat intelligence — all optional (prompted; leave blank to skip)
# Provider in use: tiered (default) | crowdsec | abuseipdb | greynoise
#                  | virustotal | abusech | multi
# "tiered" = Tier-1 local feeds (abuse.ch, local CrowdSec decisions, GeoLite2)
# always; Tier-2 per-request APIs only for IPs above the thresholds below.
ENRICHMENT_PROVIDER=tiered
CROWDSEC_LAPI_URL=http://crowdsec:8080
CROWDSEC_CTI_KEY=                 # https://app.crowdsec.net (free CTI key)
CROWDSEC_BOUNCER_KEY=             # auto-registered by setup.sh after stack start
ABUSEIPDB_KEY=
ABUSECH_KEY=                      # https://auth.abuse.ch — also unlocks the ThreatFox feed
GREYNOISE_KEY=
VIRUSTOTAL_KEY=                   # https://www.virustotal.com (free API key)
VT_ENABLE=false                   # VT free-API ToS forbids commercial use — opt-in only
MAXMIND_LICENSE_KEY=              # optional; free MaxMind account auto-downloads GeoLite2

# Tiered enrichment tuning
FEED_REFRESH_HOURS=3              # Tier-1 feed re-download interval
ENRICHMENT_CACHE_TTL_DAYS=14      # don't re-enrich an IP within this window
TIER2_MIN_EVENTS=10               # activity gate: events before Tier-2 APIs run
TIER2_MIN_THREAT_SCORE=30         # activity gate: threat_score before Tier-2 runs
TIER2_HIGH_THREAT_SCORE=60        # abuseipdb/virustotal need at least this score
ABUSEIPDB_DAILY_QUOTA=900         # hard daily budget (free tier: 1000/day)
GREYNOISE_429_COOLDOWN=21600      # backoff after 429; community quota is weekly

# Analytics tuning — edit after setup if needed
SCAN_PORT_THRESHOLD=5
SCAN_WINDOW_SECONDS=60
BRUTEFORCE_THRESHOLD=10
BRUTEFORCE_WINDOW_SECONDS=120
STATUS_INTERVAL_SECONDS=300
ENABLED_DETECTORS=scan,attack
ENABLED_PROFILERS=default
REPORT_CRON_HOUR=6

# Per-service database passwords — auto-generated by setup.sh
# Each backend service gets a least-privilege Postgres role.
# If blank, services fall back to PG_USER/PG_PASSWORD.
SVC_PIPELINE_PASSWORD=              # auto-generated (32 random hex chars)
SVC_ENRICHMENT_PASSWORD=            # auto-generated
SVC_ANALYTICS_PASSWORD=             # auto-generated
SVC_API_PASSWORD=                   # auto-generated
